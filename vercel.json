{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html",      "use": "@vercel/static" },
    { "src": "*.js",        "use": "@vercel/static" },
    { "src": "uploads/**",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/chatbot.js", "dest": "/chatbot.js" },
    { "src": "/support.js", "dest": "/support.js" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
